# Tinkoff Invest API Configuration
# Get your sandbox token at: https://www.tinkoff.ru/invest/open-api/
TINKOFF_TOKEN=your_sandbox_token_here

# WebSocket Server Configuration
WS_PORT=8081
WS_HOST=127.0.0.1

# Trading Parameters
MAX_POSITIONS=3
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
DEFAULT_RISK_PER_TRADE=1.0

# API Endpoints (for future use)
# TINKOFF_API_URL=https://invest-public-api.tinkoff.ru/rest
# TINKOFF_SANDBOX_URL=https://sandbox-invest-public-api.tinkoff.ru/rest

# Feature Flags
ENABLE_MOCK_DATA=true
ENABLE_REAL_TRADING=false
ENABLE_NOTIFICATIONS=true

# Logging
RUST_LOG=info
LOG_LEVEL=debug
