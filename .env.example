# AI Trading Bot Dashboard Configuration
# Copy this file to .env and fill in your values

# ============================================
# Tinkoff Invest API (опционально, для реальной торговли)
# Получить токен: https://tinkoff.github.io/investAPI/
# ============================================
TINKOFF_TOKEN=your_tinkoff_api_token_here
TINKOFF_SANDBOX=true

# ============================================
# WebSocket Configuration
# ============================================
WS_PORT=8081
WS_HOST=127.0.0.1

# ============================================
# Trading Settings
# ============================================
# Режим по умолчанию: DEMO, PAPER, или LIVE
DEFAULT_MODE=DEMO

# Лимиты риска
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
MAX_POSITIONS=3
MAX_EXPOSURE_RUB=500000

# ============================================
# Notifications
# ============================================
ENABLE_SOUND_ALERTS=true
ENABLE_DESKTOP_NOTIFICATIONS=true

# ============================================
# Development Settings
# ============================================
RUST_LOG=info
RUST_BACKTRACE=1
